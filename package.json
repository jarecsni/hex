{
  "name": "@hexology/hex",
  "version": "0.1.1",
  "description": "Scaffolding tool that assembles applications from templated components — honeycomb-style.",
  "keywords": [
    "scaffolding",
    "scaffold",
    "generator",
    "template",
    "components",
    "monorepo",
    "cli",
    "hex",
    "hexology"
  ],
  "homepage": "https://github.com/jarecsni/hex#readme",
  "bugs": {
    "url": "https://github.com/jarecsni/hex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarecsni/hex.git"
  },
  "author": "Johnny Jarecsni",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
